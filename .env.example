# ============================================================
# PlayFunded — Required Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ============================================================

# ------------------------------------------------------------
# DATABASE (Prisma — Supabase connection pooler)
# ------------------------------------------------------------
DATABASE_URL=                                 # postgres://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=                                   # postgres://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ------------------------------------------------------------
# SUPABASE
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=                     # https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=                # Public anon key (safe for client)
SUPABASE_SERVICE_ROLE_KEY=                    # Secret — server-side only, bypasses RLS

# ------------------------------------------------------------
# STRIPE (International card payments)
# ------------------------------------------------------------
STRIPE_SECRET_KEY=                            # sk_live_... or sk_test_...
STRIPE_WEBHOOK_SECRET=                        # whsec_... (from Stripe CLI or dashboard)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=           # pk_live_... or pk_test_...

# ------------------------------------------------------------
# NOWPAYMENTS (Crypto: USDT/USDC TRC-20, BTC)
# ------------------------------------------------------------
NOWPAYMENTS_API_KEY=                          # From NOWPayments dashboard
NOWPAYMENTS_IPN_SECRET=                       # For HMAC webhook validation
NOWPAYMENTS_PAYOUT_EMAIL=                    # NOWPayments Mass Payouts account email
NOWPAYMENTS_PAYOUT_PASSWORD=                 # NOWPayments Mass Payouts account password

# ------------------------------------------------------------
# ODDS PROVIDERS (choose per ODDS_DECISION.md)
# ------------------------------------------------------------
ODDS_API_KEY=                                 # theoddsapi.com API key
API_FOOTBALL_KEY=                             # api-football.com API key (LATAM supplement)
# BETSAPI_KEY=                                # Alternative: BetsAPI key

# ------------------------------------------------------------
# EMAIL (Resend)
# ------------------------------------------------------------
RESEND_API_KEY=                               # re_...
RESEND_FROM_EMAIL=noreply@playfunded.com

# ------------------------------------------------------------
# AI CHATBOT (Anthropic / Claude)
# ------------------------------------------------------------
ANTHROPIC_API_KEY=                            # sk-ant-...

# ------------------------------------------------------------
# EXCHANGE RATES (for currency display)
# ------------------------------------------------------------
EXCHANGERATE_API_KEY=                         # exchangerate-api.com key (free tier available)

# ------------------------------------------------------------
# GEO BLOCKING
# ------------------------------------------------------------
# ipapi.co is used for geo-detection — no API key required for free tier
# If you upgrade to a paid plan, set:
# IPAPI_KEY=

# ------------------------------------------------------------
# APP CONFIG
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://playfunded.com    # Change to http://localhost:3001 in dev
SUPPORT_EMAIL=support@playfunded.com
APP_ENV=                                      # Optional override: production | staging | preview | development

# ------------------------------------------------------------
# VERCEL CRON (backup system — Session 20)
# ------------------------------------------------------------
CRON_SECRET=                                  # Random secret to protect cron endpoint

# ------------------------------------------------------------
# OPS ALERTING (GitHub Actions health monitor)
# ------------------------------------------------------------
PF_BASE_URL=                                  # e.g. https://playfunded.com
PF_CRON_SECRET=                               # GitHub secret mirror of CRON_SECRET for /api/ops/health checks
PF_ALERT_WEBHOOK_URL=                         # Optional Slack/Discord incoming webhook URL
PF_ALERT_WEBHOOK_KIND=slack                   # "slack" or "discord"

# ------------------------------------------------------------
# KYC MALWARE SCANNING (ClamAV / clamd)
# ------------------------------------------------------------
KYC_SCAN_MODE=                                # Optional override. Default: production=require_clean, staging/preview/development=best_effort
CLAMAV_HOST=                                  # clamd host, e.g. 127.0.0.1 or internal service name
CLAMAV_PORT=3310                              # clamd TCP port
CLAMAV_TIMEOUT_MS=5000                        # scan timeout in milliseconds
KYC_QUARANTINE_BUCKET=kyc-quarantine          # private Supabase Storage bucket for blocked files

# ------------------------------------------------------------
# ASSET STORAGE (optional; if using S3-compatible media storage)
# ------------------------------------------------------------
ASSET_STORAGE_PROVIDER=                        # e.g. s3, cloudflare-r2
ASSET_STORAGE_BUCKET=
ASSET_STORAGE_REGION=
ASSET_STORAGE_ENDPOINT=
ASSET_STORAGE_PUBLIC_BASE_URL=
ASSET_STORAGE_ACCESS_KEY_ID=
ASSET_STORAGE_SECRET_ACCESS_KEY=

# ------------------------------------------------------------
# E2E TESTING (optional; never commit real credentials)
# ------------------------------------------------------------
E2E_SUPABASE_URL=
E2E_SUPABASE_ANON_KEY=
E2E_USER_EMAIL=
E2E_USER_PASSWORD=

# ------------------------------------------------------------
# SOCIAL AUTOMATION (TikTok + content pipeline)
# ------------------------------------------------------------
# TikTok credentials for approve-first Playwright upload mode
TIKTOK_SLIDES_USERNAME=
TIKTOK_SLIDES_PASSWORD=
TIKTOK_ANALYST_USERNAME=
TIKTOK_ANALYST_PASSWORD=
TIKTOK_2FA_TOTP_SECRET=

# TikTok API/OAuth (optional; only needed for API-based posting)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=

# AI providers
OPENAI_API_KEY=
RUNWAY_API_KEY=
NANOBANANA_API_KEY=
HIGGSFIELD_API_KEY=
HIGGSFIELD_BASE_URL=

# Voice generation (local repo/model paths)
VOICEBOX_REPO_PATH=
VOICEBOX_MODEL_PATH=

# Social inbox for OTP/recovery automation (if workspace policy allows)
SOCIAL_EMAIL_ADDRESS=
SOCIAL_EMAIL_APP_PASSWORD=
SOCIAL_EMAIL_LOGIN_PASSWORD=
SOCIAL_EMAIL_IMAP_HOST=imap.gmail.com
SOCIAL_EMAIL_IMAP_PORT=993
